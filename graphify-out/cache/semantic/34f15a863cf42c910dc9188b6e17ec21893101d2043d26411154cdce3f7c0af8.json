{"nodes": [{"id": "super_admin_codes_list_page", "label": "Subscription Codes List Page", "file_type": "code", "source_file": "ui/super-admin/codes-list.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "super_admin_codes_list_freecodepolicy", "label": "Free (Tk 0) subscription code is a normal, valid option", "file_type": "rationale", "source_file": "ui/super-admin/codes-list.html", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Setting price to 0 when generating a batch is a normal, valid option \u2014 it produces a free/promotional batch, not a special/hidden case. Redeeming a free code still counts as code history and permanently ends Trial status the same as a paid code. Because a redeemed code (free or paid) can never be deleted, its Delete action is always shown disabled."}], "edges": [{"source": "super_admin_codes_list_page", "target": "super_admin_codes_batch_generate_page", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ui/super-admin/codes-list.html", "source_location": null, "weight": 1.0}, {"source": "super_admin_codes_list_page", "target": "super_admin_codes_list_freecodepolicy", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ui/super-admin/codes-list.html", "source_location": null, "weight": 1.0}, {"source": "super_admin_codes_list_page", "target": "super_admin_schools_list_adarshahighschool", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "ui/super-admin/codes-list.html", "source_location": null, "weight": 1.0}], "hyperedges": []}